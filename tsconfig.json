{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",              // Backend ke liye NodeNext best hai
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*",                        // Saara source code
    "src/types/**/*.d.ts"              // Aapki custom express.d.ts file
  ],
  "exclude": ["node_modules", "dist"]
}