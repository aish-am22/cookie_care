generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  fullName        String?
  role            UserRole  @default(USER)
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
  scanRecords             ScanRecord[]

  @@index([role])
  @@index([createdAt])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // store hashed refresh token (never raw token)
  refreshTokenHash String
  status           SessionStatus @default(ACTIVE)

  userAgent String?
  ipAddress String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model PasswordResetToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // hashed token
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // hashed token
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String
  resource String?
  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum ScanType {
  COOKIE
  LEGAL
  VULNERABILITY
}

enum ScanStatus {
  COMPLETED
  FAILED
}

model ScanRecord {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ScanType
  status    ScanStatus @default(COMPLETED)
  target    String
  riskScore Int?
  findings  Int?
  metadata  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}
